# URL of the Express.js backend (used by the Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:5000

# -------------------------------------------------------------------
# The following variables belong in the Express backend's .env file.
# They are listed here for reference so you know what to configure.
# -------------------------------------------------------------------

# SPOTIFY_CLIENT_ID=your_spotify_client_id
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# SPOTIFY_REDIRECT_URI=http://localhost:5000/auth/spotify/callback
# SESSION_SECRET=a_long_random_string
